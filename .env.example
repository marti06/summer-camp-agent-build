# Copy this to .env and fill it in:   cp .env.example .env
# Then load it into your shell before running Claude Code:
#   set -a && source .env && set +a
#   claude

# ───────────────────────── REQUIRED ─────────────────────────
# Your Anthropic API key. Powers Claude Code and the whole agent
# (research, review, judge). The agent's web search & fetch are
# BUILT INTO Claude Code, you do NOT need a separate search key.
# At the summit, a key is provided for you.
# (Alternatively, skip this and run `claude login` with a subscription.)
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────── OPTIONAL, only to PUBLISH to Stacklist ────────────────
# Leave this unset and /build-stack writes the stack to output/<slug>.md
# (fully hands-on, no account needed).
#
# To publish a real, AI-discoverable Stacklist stack instead, connect the
# Stacklist MCP server (see phases/PHASE-4.md) and provide its credential
# here. Match the variable name your Stacklist MCP setup expects, the name
# below is a placeholder.
# STACKLIST_API_KEY=
